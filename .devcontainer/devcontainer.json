{
  "name": "ollama-completion.nvim devcontainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--add-host=host.docker.internal:host-gateway"
  ],
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/goropikari/devcontainer-feature/neovim:1": {},
    "ghcr.io/goropikari/devcontainer-feature/tree-sitter:1": {}
  },
  "mounts": [
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.claude",
      "target": "/home/vscode/.claude"
    },
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.config/nvim",
      "target": "/home/vscode/.config/nvim"
    }
  ],
  "postCreateCommand": [
    "make -C .devcontainer setup"
  ]
}
